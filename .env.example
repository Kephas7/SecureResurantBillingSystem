# Copy to .env and replace all values before running.
# NEVER commit the real .env file.

# --- Postgres ---
POSTGRES_USER=restaurant_app
POSTGRES_PASSWORD=change_me_to_a_long_random_value
POSTGRES_DB=restaurant_secure
# Host port mapping for local dev only (container always listens on 5432
# internally). Default 5432 conflicts if you have a native Postgres install
# running on the host - change to 5433 (or any free port) if so.
POSTGRES_PORT=5432
DATABASE_URL=postgresql://restaurant_app:change_me_to_a_long_random_value@postgres:5432/restaurant_secure?schema=public

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_too

# --- API ---
API_PORT=4000
NODE_ENV=development

# Session/cookie secret - generate with: openssl rand -base64 48
SESSION_SECRET=replace_with_long_random_string

# JWT (if used for API access tokens)
JWT_ACCESS_SECRET=replace_with_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_REFRESH_EXPIRES_IN=7d

# MFA (TOTP) issuer name shown in authenticator apps
MFA_ISSUER=RestaurantSecure

# Argon2id tuning (defaults are reasonable; document choice in report)
ARGON2_MEMORY_COST=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1

# CAPTCHA (e.g. hCaptcha or Turnstile) - register your own site/secret keys
CAPTCHA_SITE_KEY=
CAPTCHA_SECRET_KEY=

# CORS - frontend origin allowed to call the API
WEB_ORIGIN=http://localhost:3000

# --- Web (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:4000
